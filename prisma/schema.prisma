generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "cockroachdb"
}

enum UserRole {
  CUSTOMER
  ATTENDANT
  MEDIA_MANAGER
  MODERATOR
  SUPER_ADMIN
}

enum AdminProfileStatus {
  ACTIVE
  SUSPENDED
}

enum ProductStatus {
  ACTIVE
  HIDDEN
  OUT_OF_STOCK
}

enum MediaAssetStatus {
  PENDING_UPLOAD
  READY
  DELETED
}

enum MediaUploadPurpose {
  PRODUCT_IMAGE
}

enum DeliveryMethod {
  DELIVERY
  PICKUP
}

enum CustomerType {
  GUEST
  AUTHENTICATED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAYMENT_UNDER_REVIEW
  PAYMENT_CONFIRMED
  PREPARING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REJECTED
}

enum PaymentStatus {
  UNPAID
  PROOF_SENT_ON_WHATSAPP
  UNDER_REVIEW
  CONFIRMED
  REJECTED
}

enum PaymentMethod {
  BANK_TRANSFER
}

enum EmailTemplateKey {
  ORDER_CONFIRMATION
  PURCHASE_INVOICE
  AUTH_PASSWORD_RESET
  ADMIN_NEW_ORDER_ALERT
  ORDER_STATUS_UPDATE
  APPRECIATION_AFTER_DELIVERY
}

enum EmailOutboxStatus {
  QUEUED
  PROCESSING
  SENT
  FAILED
  SKIPPED
}

enum EmailEventType {
  QUEUED
  SENT
  FAILED
  RETRIED
  SKIPPED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  phone         String?
  passwordHash  String?   @map("password_hash")
  passwordUpdatedAt DateTime? @map("password_updated_at")
  failedLoginCount Int     @default(0) @map("failed_login_count")
  lockedUntil   DateTime? @map("locked_until")
  role          UserRole  @default(CUSTOMER)
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts     Account[]
  sessions     Session[]
  adminProfile AdminProfile?
  customerProfile CustomerProfile?
  auditLogs    AuditLog[]    @relation("AuditActor")
  mediaAssets  MediaAsset[]  @relation("MediaAssetCreator")
  carts        Cart[]
  orders       Order[]
  reviews      Review[]      @relation("ReviewAuthor")
  reviewedReviews Review[]   @relation("ReviewModerator")
  orderStatusEvents OrderStatusEvent[] @relation("OrderStatusEventActor")
  paymentSettingsUpdated PaymentSetting[] @relation("PaymentSettingUpdater")
  paymentConfirmationEvents PaymentConfirmationEvent[] @relation("PaymentConfirmationEventActor")
  emailTemplatesUpdated EmailTemplate[] @relation("EmailTemplateUpdater")
  homepageHeroProductsUpdated HomepageHeroProduct[] @relation("HomepageHeroProductUpdater")
  emailPreference EmailPreference?

  @@index([lockedUntil])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model AdminProfile {
  id        String             @id @default(cuid())
  userId    String             @unique @map("user_id")
  role      UserRole
  status    AdminProfileStatus @default(ACTIVE)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([role])
  @@index([status])
  @@map("admin_profiles")
}

model CustomerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  fullName  String   @map("full_name")
  phone     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone])
  @@map("customer_profiles")
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  products Product[]

  @@index([isActive, sortOrder])
  @@map("categories")
}

model Product {
  id                 String        @id @default(cuid())
  categoryId         String        @map("category_id")
  name               String
  slug               String        @unique
  description        String?
  basePrice          Int           @map("base_price")
  status             ProductStatus @default(ACTIVE)
  showWhenOutOfStock Boolean       @default(true) @map("show_when_out_of_stock")
  isFeatured         Boolean       @default(false) @map("is_featured")
  isPopular          Boolean       @default(false) @map("is_popular")
  sortOrder          Int           @default(0) @map("sort_order")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  category Category         @relation(fields: [categoryId], references: [id])
  variants ProductVariant[]
  images   ProductImage[]
  cartItems CartItem[]
  orderItems OrderItem[]
  reviews Review[]
  homepageHeroProducts HomepageHeroProduct[]

  @@index([categoryId])
  @@index([status, sortOrder])
  @@index([isFeatured])
  @@index([isPopular])
  @@map("products")
}

model HomepageHeroProduct {
  id              String   @id @default(cuid())
  productId       String   @unique @map("product_id")
  sortOrder       Int      @default(0) @map("sort_order")
  isActive        Boolean  @default(true) @map("is_active")
  updatedByUserId String?  @map("updated_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  updatedBy User?   @relation("HomepageHeroProductUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([isActive, sortOrder])
  @@index([updatedByUserId])
  @@map("homepage_hero_products")
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  name      String
  price     Int
  sku       String?
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems CartItem[]
  orderItems OrderItem[]

  @@index([productId, isActive, sortOrder])
  @@index([sku])
  @@map("product_variants")
}

model ProductImage {
  id           String   @id @default(cuid())
  productId    String   @map("product_id")
  mediaAssetId String   @map("media_asset_id")
  altText      String?  @map("alt_text")
  isPrimary    Boolean  @default(false) @map("is_primary")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  mediaAsset MediaAsset @relation(fields: [mediaAssetId], references: [id])

  @@unique([productId, mediaAssetId])
  @@index([productId, isPrimary, sortOrder])
  @@index([mediaAssetId])
  @@map("product_images")
}

model MediaAsset {
  id               String             @id @default(cuid())
  bucket           String
  objectKey        String             @unique @map("object_key")
  publicUrl        String?            @map("public_url")
  originalFilename String             @map("original_filename")
  contentType      String             @map("content_type")
  byteSize         Int                @map("byte_size")
  uploadPurpose    MediaUploadPurpose @map("upload_purpose")
  status           MediaAssetStatus   @default(PENDING_UPLOAD)
  createdByUserId  String?            @map("created_by_user_id")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  createdBy     User?          @relation("MediaAssetCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  productImages ProductImage[]

  @@index([status])
  @@index([uploadPurpose])
  @@index([createdByUserId])
  @@map("media_assets")
}

model DeliveryZone {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  baseFee     Int      @map("base_fee")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orders Order[]

  @@index([isActive, sortOrder])
  @@map("delivery_zones")
}

model DeliverySurchargeRule {
  id           String   @id @default(cuid())
  name         String
  startsAtTime String   @map("starts_at_time")
  endsAtTime   String?  @map("ends_at_time")
  amount       Int
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([isActive, startsAtTime])
  @@map("delivery_surcharge_rules")
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String   @map("cart_id")
  productId String   @map("product_id")
  variantId String?  @map("variant_id")
  quantity  Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([cartId, productId, variantId])
  @@index([cartId])
  @@index([productId])
  @@index([variantId])
  @@map("cart_items")
}

model Order {
  id                         String         @id @default(cuid())
  orderNumber                String         @unique @map("order_number")
  idempotencyKey             String?        @unique @map("idempotency_key")
  idempotencyRequestHash     String?        @map("idempotency_request_hash")
  userId                     String?        @map("user_id")
  customerType               CustomerType   @map("customer_type")
  customerNameSnapshot       String         @map("customer_name_snapshot")
  customerPhoneSnapshot      String         @map("customer_phone_snapshot")
  customerEmailSnapshot      String?        @map("customer_email_snapshot")
  deliveryMethod             DeliveryMethod @map("delivery_method")
  deliveryAddressSnapshot    String?        @map("delivery_address_snapshot")
  deliveryZoneId             String?        @map("delivery_zone_id")
  deliveryZoneNameSnapshot   String?        @map("delivery_zone_name_snapshot")
  deliveryBaseFeeSnapshot    Int            @map("delivery_base_fee_snapshot")
  deliverySurchargeSnapshot  Int            @map("delivery_surcharge_snapshot")
  deliveryTotalFeeSnapshot   Int            @map("delivery_total_fee_snapshot")
  subtotal                   Int
  total                      Int
  status                     OrderStatus    @default(PENDING_PAYMENT)
  paymentStatus              PaymentStatus  @default(UNPAID) @map("payment_status")
  paymentMethod              PaymentMethod  @default(BANK_TRANSFER) @map("payment_method")
  paymentInstructionSnapshot String         @map("payment_instruction_snapshot")
  proofWhatsappNumberSnapshot String?       @map("proof_whatsapp_number_snapshot")
  customerNote               String?        @map("customer_note")
  adminNote                  String?        @map("admin_note")
  createdAt                  DateTime       @default(now()) @map("created_at")
  updatedAt                  DateTime       @updatedAt @map("updated_at")
  cancelledAt                DateTime?      @map("cancelled_at")
  deliveredAt                DateTime?      @map("delivered_at")

  user         User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  deliveryZone DeliveryZone?      @relation(fields: [deliveryZoneId], references: [id], onDelete: SetNull)
  items        OrderItem[]
  statusEvents OrderStatusEvent[]
  paymentConfirmationEvents PaymentConfirmationEvent[]
  invoice      Invoice?
  emailOutbox  EmailOutbox[]
  reviews      Review[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([paymentStatus, createdAt])
  @@index([customerType, createdAt])
  @@index([customerPhoneSnapshot])
  @@index([createdAt])
  @@map("orders")
}

model Invoice {
  id                String   @id @default(cuid())
  orderId           String   @unique @map("order_id")
  invoiceNumber     String   @unique @map("invoice_number")
  publicAccessToken String   @unique @map("public_access_token")
  htmlSnapshot      String   @map("html_snapshot")
  pdfUrl            String?  @map("pdf_url")
  generatedAt       DateTime @default(now()) @map("generated_at")
  createdAt         DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([generatedAt])
  @@map("invoices")
}

model EmailTemplate {
  id                       String           @id @default(cuid())
  key                      EmailTemplateKey @unique
  name                     String
  subject                  String
  bodySchemaOrComponentKey String           @map("body_schema_or_component_key")
  isActive                 Boolean          @default(true) @map("is_active")
  updatedByUserId          String?          @map("updated_by_user_id")
  createdAt                DateTime         @default(now()) @map("created_at")
  updatedAt                DateTime         @updatedAt @map("updated_at")

  updatedBy User? @relation("EmailTemplateUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([updatedByUserId])
  @@map("email_templates")
}

model EmailOutbox {
  id              String            @id @default(cuid())
  orderId         String?           @map("order_id")
  recipientEmail  String            @map("recipient_email")
  recipientName   String?           @map("recipient_name")
  templateKey     EmailTemplateKey  @map("template_key")
  subjectSnapshot String            @map("subject_snapshot")
  htmlSnapshot    String            @map("html_snapshot")
  payloadJson     Json              @map("payload_json")
  status          EmailOutboxStatus @default(QUEUED)
  resendEmailId   String?           @map("resend_email_id")
  errorMessage    String?           @map("error_message")
  attemptCount    Int               @default(0) @map("attempt_count")
  nextAttemptAt   DateTime?         @map("next_attempt_at")
  sentAt          DateTime?         @map("sent_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  order  Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  events EmailEvent[]

  @@unique([orderId, templateKey, recipientEmail])
  @@index([status, nextAttemptAt])
  @@index([templateKey, status])
  @@index([recipientEmail])
  @@map("email_outbox")
}

model EmailEvent {
  id            String         @id @default(cuid())
  emailOutboxId String         @map("email_outbox_id")
  eventType     EmailEventType @map("event_type")
  message       String?
  resendEmailId String?        @map("resend_email_id")
  errorMessage  String?        @map("error_message")
  createdAt     DateTime       @default(now()) @map("created_at")

  emailOutbox EmailOutbox @relation(fields: [emailOutboxId], references: [id], onDelete: Cascade)

  @@index([emailOutboxId, createdAt])
  @@index([eventType, createdAt])
  @@map("email_events")
}

model EmailPreference {
  id                   String   @id @default(cuid())
  userId               String   @unique @map("user_id")
  transactionalEnabled Boolean  @default(true) @map("transactional_enabled")
  marketingEnabled     Boolean  @default(false) @map("marketing_enabled")
  appreciationEnabled  Boolean  @default(true) @map("appreciation_enabled")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_preferences")
}

model PaymentSetting {
  id                  String   @id @default(cuid())
  settingKey          String   @unique @default("default") @map("setting_key")
  bankName            String   @map("bank_name")
  accountName         String   @map("account_name")
  accountNumber       String   @map("account_number")
  paymentInstruction  String   @map("payment_instruction")
  proofWhatsappNumber String   @map("proof_whatsapp_number")
  isActive            Boolean  @default(true) @map("is_active")
  updatedByUserId     String?  @map("updated_by_user_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  updatedBy User? @relation("PaymentSettingUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([updatedByUserId])
  @@map("payment_settings")
}

model OrderItem {
  id                  String   @id @default(cuid())
  orderId             String   @map("order_id")
  productId           String?  @map("product_id")
  variantId           String?  @map("variant_id")
  productNameSnapshot String   @map("product_name_snapshot")
  variantNameSnapshot String?  @map("variant_name_snapshot")
  unitPriceSnapshot   Int      @map("unit_price_snapshot")
  quantity            Int
  lineTotal           Int      @map("line_total")
  createdAt           DateTime @default(now()) @map("created_at")

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@map("order_items")
}

model OrderStatusEvent {
  id              String       @id @default(cuid())
  orderId         String       @map("order_id")
  fromStatus      OrderStatus? @map("from_status")
  toStatus        OrderStatus  @map("to_status")
  changedByUserId String?      @map("changed_by_user_id")
  reason          String?
  createdAt       DateTime     @default(now()) @map("created_at")

  order         Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedByUser User? @relation("OrderStatusEventActor", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@index([toStatus, createdAt])
  @@index([changedByUserId])
  @@map("order_status_events")
}

model PaymentConfirmationEvent {
  id              String        @id @default(cuid())
  orderId         String        @map("order_id")
  fromStatus      PaymentStatus @map("from_status")
  toStatus        PaymentStatus @map("to_status")
  changedByUserId String?       @map("changed_by_user_id")
  reason          String?
  createdAt       DateTime      @default(now()) @map("created_at")

  order         Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedByUser User? @relation("PaymentConfirmationEventActor", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@index([toStatus, createdAt])
  @@index([changedByUserId])
  @@map("payment_confirmation_events")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?  @map("actor_user_id")
  action      String
  targetType  String   @map("target_type")
  targetId    String?  @map("target_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Review {
  id                   String       @id @default(cuid())
  userId               String?      @map("user_id")
  orderId              String?      @map("order_id")
  productId            String?      @map("product_id")
  customerNameSnapshot String       @map("customer_name_snapshot")
  rating               Int
  comment              String
  status               ReviewStatus @default(PENDING)
  reviewedByUserId     String?      @map("reviewed_by_user_id")
  moderationReason     String?      @map("moderation_reason")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  user       User?    @relation("ReviewAuthor", fields: [userId], references: [id], onDelete: SetNull)
  order      Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  product    Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  reviewedBy User?    @relation("ReviewModerator", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([productId, status])
  @@index([orderId])
  @@index([userId])
  @@index([reviewedByUserId])
  @@map("reviews")
}
