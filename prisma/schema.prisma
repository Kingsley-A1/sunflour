generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "cockroachdb"
}

enum UserRole {
  CUSTOMER
  MODERATOR
  SUPER_ADMIN
}

enum AdminProfileStatus {
  ACTIVE
  SUSPENDED
}

enum ProductStatus {
  ACTIVE
  HIDDEN
  OUT_OF_STOCK
}

enum MediaAssetStatus {
  PENDING_UPLOAD
  READY
  DELETED
}

enum MediaUploadPurpose {
  PRODUCT_IMAGE
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  phone         String?
  role          UserRole  @default(CUSTOMER)
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts     Account[]
  sessions     Session[]
  adminProfile AdminProfile?
  auditLogs    AuditLog[]    @relation("AuditActor")
  mediaAssets  MediaAsset[]  @relation("MediaAssetCreator")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model AdminProfile {
  id        String             @id @default(cuid())
  userId    String             @unique @map("user_id")
  role      UserRole
  status    AdminProfileStatus @default(ACTIVE)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([role])
  @@index([status])
  @@map("admin_profiles")
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  products Product[]

  @@index([isActive, sortOrder])
  @@map("categories")
}

model Product {
  id                 String        @id @default(cuid())
  categoryId         String        @map("category_id")
  name               String
  slug               String        @unique
  description        String?
  basePrice          Int           @map("base_price")
  status             ProductStatus @default(ACTIVE)
  showWhenOutOfStock Boolean       @default(true) @map("show_when_out_of_stock")
  isFeatured         Boolean       @default(false) @map("is_featured")
  isPopular          Boolean       @default(false) @map("is_popular")
  sortOrder          Int           @default(0) @map("sort_order")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  category Category         @relation(fields: [categoryId], references: [id])
  variants ProductVariant[]
  images   ProductImage[]

  @@index([categoryId])
  @@index([status, sortOrder])
  @@index([isFeatured])
  @@index([isPopular])
  @@map("products")
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  name      String
  price     Int
  sku       String?
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, isActive, sortOrder])
  @@index([sku])
  @@map("product_variants")
}

model ProductImage {
  id           String   @id @default(cuid())
  productId    String   @map("product_id")
  mediaAssetId String   @map("media_asset_id")
  altText      String?  @map("alt_text")
  isPrimary    Boolean  @default(false) @map("is_primary")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  mediaAsset MediaAsset @relation(fields: [mediaAssetId], references: [id])

  @@unique([productId, mediaAssetId])
  @@index([productId, isPrimary, sortOrder])
  @@index([mediaAssetId])
  @@map("product_images")
}

model MediaAsset {
  id               String             @id @default(cuid())
  bucket           String
  objectKey        String             @unique @map("object_key")
  publicUrl        String?            @map("public_url")
  originalFilename String             @map("original_filename")
  contentType      String             @map("content_type")
  byteSize         Int                @map("byte_size")
  uploadPurpose    MediaUploadPurpose @map("upload_purpose")
  status           MediaAssetStatus   @default(PENDING_UPLOAD)
  createdByUserId  String?            @map("created_by_user_id")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  createdBy     User?          @relation("MediaAssetCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  productImages ProductImage[]

  @@index([status])
  @@index([uploadPurpose])
  @@index([createdByUserId])
  @@map("media_assets")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?  @map("actor_user_id")
  action      String
  targetType  String   @map("target_type")
  targetId    String?  @map("target_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}
