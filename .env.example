# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_TIME_ZONE=Africa/Lagos

# Auth.js / NextAuth
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET="<generate-with-openssl-rand-base64-32>"
AUTH_GOOGLE_ID="<google-oauth-client-id>"
AUTH_GOOGLE_SECRET="<google-oauth-client-secret>"
ADMIN_ALLOWLIST_EMAILS="owner@example.com:SUPER_ADMIN,manager@example.com:MODERATOR"

# CockroachDB / Prisma
DATABASE_URL="postgresql://<user>:<password>@<host>:26257/<database>?sslmode=verify-full"
TEST_DATABASE_URL="postgresql://<user>:<password>@<host>:26257/<test_database>?sslmode=verify-full"
SHADOW_DATABASE_URL="postgresql://<user>:<password>@<host>:26257/<shadow_database>?sslmode=verify-full"
RUN_DB_TESTS=false
