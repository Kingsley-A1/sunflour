# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_TIME_ZONE=Africa/Lagos

# Auth.js / NextAuth
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET="<generate-with-openssl-rand-base64-32>"
AUTH_GOOGLE_ID="<google-oauth-client-id>"
AUTH_GOOGLE_SECRET="<google-oauth-client-secret>"
ADMIN_REGISTRATION_CODE_SECRET="<generate-with-openssl-rand-base64-32>"
ADMIN_ALLOWLIST_EMAILS="owner@example.com:SUPER_ADMIN,manager@example.com:MODERATOR"

# Resend transactional email
RESEND_API_KEY="<resend-api-key>"
EMAIL_FROM_ADDRESS="orders@example.com"
EMAIL_FROM_NAME="Sunflour Bakery"
EMAIL_SENDING_ENABLED=false
EMAIL_OUTBOX_BATCH_SIZE=10
EMAIL_CRON_SECRET="<shared-cron-secret>"
ADMIN_ORDER_ALERT_EMAILS="owner@example.com,manager@example.com"

# Cloudflare R2
R2_ACCOUNT_ID="<cloudflare-account-id>"
R2_ACCESS_KEY_ID="<r2-access-key-id>"
R2_SECRET_ACCESS_KEY="<r2-secret-access-key>"
R2_BUCKET_NAME="sunflour-media"
R2_PUBLIC_BASE_URL="https://media.example.com"
R2_PRESIGNED_UPLOAD_EXPIRES_SECONDS=300

# Optional seed data
SUNFLOUR_MENU_SEED_PATH=

# CockroachDB / Prisma
DATABASE_URL="postgresql://sunflour_user:replace-me@localhost:26257/sunflour?sslmode=disable"
TEST_DATABASE_URL=
SHADOW_DATABASE_URL=
RUN_DB_TESTS=false

# Public business contacts
PHONE_NUMBER=
WHATSAPP_NUMBER=
EMAIL_ADDRESS=
INSTAGRAM=
TIKTOK=
FACEBOOK=
ADDRESS=
